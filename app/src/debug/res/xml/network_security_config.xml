<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only: allows plain ws:// to the dev machine's LAN IP for testing the
  relay before it's deployed with TLS on Render. Release builds don't merge
  this file, so they stay on the default HTTPS-only policy.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.0.12</domain>
    </domain-config>
</network-security-config>
